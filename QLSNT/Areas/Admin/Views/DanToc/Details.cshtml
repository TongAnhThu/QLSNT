@model QLSNT.Models.DanToc

@{
    ViewData["Title"] = "Chi tiết Dân tộc";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="fw-bold text-primary mb-4">
    <i class="bi bi-info-circle"></i> @ViewData["Title"]
</h2>

<dl class="row">
    <dt class="col-sm-3">Mã Dân tộc</dt>
    <dd class="col-sm-9">@Model.MaDanToc</dd>

    <dt class="col-sm-3">Tên Dân tộc</dt>
    <dd class="col-sm-9">@Model.TenDanToc</dd>

    <dt class="col-sm-3">Tên khác</dt>
    <dd class="col-sm-9">@Model.TenKhac</dd>

    <dt class="col-sm-3">Mô tả</dt>
    <dd class="col-sm-9">@Model.MoTa</dd>

    <dt class="col-sm-3">Ghi chú</dt>
    <dd class="col-sm-9">@Model.GhiChu</dd>
</dl>

<div class="text-end">
    <a asp-action="Edit" asp-route-id="@Model.MaDanToc" class="btn btn-warning">
        <i class="bi bi-pencil-square"></i> Sửa
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>
