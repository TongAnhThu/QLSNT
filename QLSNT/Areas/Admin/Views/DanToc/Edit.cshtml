@model QLSNT.Models.DanToc

@{
    ViewData["Title"] = "Chỉnh sửa Dân tộc";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="fw-bold text-primary mb-4">
    <i class="bi bi-pencil-square"></i> @ViewData["Title"]
</h2>

<div class="card shadow-sm p-4">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        <!-- Mã Dân tộc -->
        <div class="mb-3">
            <label asp-for="MaDanToc" class="form-label"></label>
            <input asp-for="MaDanToc" class="form-control" readonly />
        </div>

        <!-- Tên Dân tộc -->
        <div class="mb-3">
            <label asp-for="TenDanToc" class="form-label"></label>
            <input asp-for="TenDanToc" class="form-control" />
            <span asp-validation-for="TenDanToc" class="text-danger"></span>
        </div>

        <!-- Tên khác -->
        <div class="mb-3">
            <label asp-for="TenKhac" class="form-label"></label>
            <input asp-for="TenKhac" class="form-control" />
        </div>

        <!-- Mô tả -->
        <div class="mb-3">
            <label asp-for="MoTa" class="form-label"></label>
            <textarea asp-for="MoTa" class="form-control"></textarea>
        </div>

        <!-- Ghi chú -->
        <div class="mb-3">
            <label asp-for="GhiChu" class="form-label"></label>
            <textarea asp-for="GhiChu" class="form-control"></textarea>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Lưu
            </button>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
