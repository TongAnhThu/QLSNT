@model QLSNT.Models.HuyenCu

@{
    ViewData["Title"] = "Thêm Huyện cũ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">@ViewData["Title"]</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input asp-for="MaHuyenCu" type="hidden" />

                <div class="mb-3">
                    <label asp-for="TenHuyenCu" class="form-label fw-bold">Tên Huyện cũ</label>
                    <input asp-for="TenHuyenCu" class="form-control" placeholder="Nhập tên huyện/quận/thị xã..." />
                    <span asp-validation-for="TenHuyenCu" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LoaiHuyen" class="form-label fw-bold">Loại Huyện</label>
                    <select asp-for="LoaiHuyen" class="form-select">
                        <option value="">-- Chọn loại huyện --</option>
                        <option value="Huyện">Huyện</option>
                        <option value="Quận">Quận</option>
                        <option value="Thị xã">Thị xã</option>
                        <option value="Thành phố">Thành phố</option>
                    </select>
                    <span asp-validation-for="LoaiHuyen" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái</label>
                    <select asp-for="TrangThai" class="form-select">
                        <option value="">-- Chọn trạng thái --</option>
                        <option value="Hoạt động">Hoạt động</option>
                        <option value="Đã sáp nhập">Đã sáp nhập</option>
                    </select>
                    <span asp-validation-for="TrangThai" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MaTinhCu" class="form-label fw-bold">Thuộc Tỉnh cũ</label>
                    <select asp-for="MaTinhCu" class="form-select"
                            asp-items="@(new SelectList(ViewBag.TinhCus, "MaTinhCu", "TenTinhCu"))">
                        <option value="">-- Chọn Tỉnh cũ --</option>
                    </select>
                    <span asp-validation-for="MaTinhCu" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label fw-bold">Ghi chú</label>
                    <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Ghi chú thêm..."></textarea>
                    <span asp-validation-for="GhiChu" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-success me-2">
                        <i class="bi bi-plus-circle"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
