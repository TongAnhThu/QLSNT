@model QLSNT.Models.LichSuSapNhap

@{
    ViewData["Title"] = "Xóa lịch sử sáp nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="fw-bold text-danger mb-4">
    <i class="bi bi-trash"></i> @ViewData["Title"]
</h2>

<div class="alert alert-danger">
    <p>
        Bạn có chắc chắn muốn xóa bản ghi lịch sử sáp nhập
        <strong>@Model.MaLSSN</strong>
        (Số nghị định: <strong>@Model.SoNghiDinh</strong>) không?
    </p>
</div>

<dl class="row">
    <dt class="col-sm-3">Người tạo</dt>
    <dd class="col-sm-9">@Model.NguoiTao</dd>

    <dt class="col-sm-3">Ngày tạo</dt>
    <dd class="col-sm-9">@Model.NgayTao</dd>

    <dt class="col-sm-3">Ghi chú</dt>
    <dd class="col-sm-9">@Model.GhiChu</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="MaLSSN" />

    <div class="text-end mt-3">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xóa
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Hủy
        </a>
    </div>
</form>
