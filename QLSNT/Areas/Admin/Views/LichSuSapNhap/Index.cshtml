@model IEnumerable<QLSNT.Models.LichSuSapNhap>

@{
    ViewData["Title"] = "Danh sách lịch sử sáp nhập";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold text-primary">
        <i class="bi bi-clock-history"></i> @ViewData["Title"]
    </h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Thêm lịch sử sáp nhập
    </a>
</div>

<form asp-action="Index" method="get" class="mb-4">
    <div class="row g-2">
        <div class="col-md-6 col-lg-4">
            <input type="text"
                   name="search"
                   value="@(ViewBag.Search ?? "")"
                   class="form-control"
                   placeholder="Tìm theo mã, số nghị định, ghi chú..." />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-search"></i> Tìm kiếm
            </button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">
                <i class="bi bi-x-circle"></i> Xóa lọc
            </a>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Mã LSSN</th>
                <th>Loại bản ghi</th>
                <th>Từ cũ → thành mới</th>
                <th>Người tạo</th>
                <th>Ngày tạo</th>
                <th>Ghi chú</th>
                <th class="text-center" style="width: 220px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">
                        <i class="bi bi-info-circle"></i> Không có bản ghi nào.
                    </td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaLSSN</td>
                        <td>
                            @if (item.LssnTinhs.Any())
                            {
                                <span class="badge bg-primary">Tỉnh</span>
                            }
                            else if (item.LssnXas.Any())
                            {
                                <span class="badge bg-success">Xã</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Không xác định</span>
                            }
                        </td>
                        <td>
                            @if (item.LssnTinhs.Any())
                            {
                                foreach (var t in item.LssnTinhs)
                                {
                                    <div>@($"{t.TinhCu?.TenTinhCu} → {t.TinhMoi?.TenTinhMoi}")</div>
                                }
                            }
                            else if (item.LssnXas.Any())
                            {
                                foreach (var x in item.LssnXas)
                                {
                                    <div>@($"{x.XaCu?.TenXaCu} → {x.XaMoi?.TenXaMoi}")</div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>@item.NguoiTao</td>
                        <td>@item.NgayTao?.ToString("dd/MM/yyyy")</td>
                        <td>@(string.IsNullOrEmpty(item.GhiChu) ? "-" : item.GhiChu)</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.MaLSSN" class="btn btn-sm btn-info me-1">
                                <i class="bi bi-eye"></i> Chi tiết
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.MaLSSN" class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.MaLSSN" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
