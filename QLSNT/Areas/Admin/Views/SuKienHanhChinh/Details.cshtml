@model QLSNT.Models.SuKienHanhChinh

@{
    ViewData["Title"] = "Chi tiết sự kiện hành chính";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>@ViewData["Title"]</h1>
<hr />

<dl class="row">
    <dt class="col-sm-3">Số Nghị định</dt>
    <dd class="col-sm-9">@Model.SoNghiDinh</dd>

    <dt class="col-sm-3">Tên sự kiện</dt>
    <dd class="col-sm-9">@Model.TenSK</dd>

    <dt class="col-sm-3">Mô tả chi tiết</dt>
    <dd class="col-sm-9">@Model.MoTaChiTiet</dd>

    <dt class="col-sm-3">Căn cứ pháp lý</dt>
    <dd class="col-sm-9">@Model.CanCuPhapLy</dd>

    <dt class="col-sm-3">Cơ quan ban hành</dt>
    <dd class="col-sm-9">@Model.CoQuanBanHanh</dd>

    <dt class="col-sm-3">Ngày ban hành</dt>
    <dd class="col-sm-9">@Model.NgayBanHanh?.ToString("dd/MM/yyyy")</dd>

    <dt class="col-sm-3">Trạng thái</dt>
    <dd class="col-sm-9">@Model.TrangThai</dd>

    <dt class="col-sm-3">Ghi chú</dt>
    <dd class="col-sm-9">@Model.GhiChu</dd>

    <dt class="col-sm-3">Ngày tạo</dt>
    <dd class="col-sm-9">@Model.NgayTao?.ToString("dd/MM/yyyy")</dd>

    <dt class="col-sm-3">Người tạo</dt>
    <dd class="col-sm-9">@Model.NguoiTao</dd>
</dl>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.SoNghiDinh" class="btn btn-warning">Sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</div>
