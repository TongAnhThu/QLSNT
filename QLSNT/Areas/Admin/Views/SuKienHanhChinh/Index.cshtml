@model IEnumerable<QLSNT.Models.SuKienHanhChinh>

@{
    ViewData["Title"] = "Danh sách sự kiện hành chính";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<h1>@ViewData["Title"]</h1>
<hr />

<p>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Thêm mới</a>
</p>

<table class="table table-bordered table-striped">
    <thead class="table-light">
        <tr>
            <th>Số Nghị định</th>
            <th>Tên sự kiện</th>
            <th>Ngày ban hành</th>
            <th>Cơ quan ban hành</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.SoNghiDinh</td>
                <td>@item.TenSK</td>
                <td>@item.NgayBanHanh?.ToString("dd/MM/yyyy")</td>
                <td>@item.CoQuanBanHanh</td>
                <td>@item.TrangThai</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.SoNghiDinh" class="btn btn-info btn-sm">Chi tiết</a>
                    <a asp-action="Edit" asp-route-id="@item.SoNghiDinh" class="btn btn-warning btn-sm">Sửa</a>
                    <a asp-action="Delete" asp-route-id="@item.SoNghiDinh" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
