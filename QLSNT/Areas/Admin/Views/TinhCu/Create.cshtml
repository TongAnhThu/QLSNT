@model QLSNT.Models.TinhCu

@{
    ViewData["Title"] = "Thêm Tỉnh cũ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">@ViewData["Title"]</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <input asp-for="MaTinhCu" type="hidden" />

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="TenTinhCu" class="form-label fw-bold">Tên Tỉnh</label>
                        <input asp-for="TenTinhCu" class="form-control" placeholder="Nhập tên tỉnh/thành phố" />
                        <span asp-validation-for="TenTinhCu" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LoaiTinh" class="form-label fw-bold">Loại Tỉnh</label>
                        <select asp-for="LoaiTinh" class="form-select">
                            <option value="">-- Chọn loại tỉnh --</option>
                            <option value="Tỉnh">Tỉnh</option>
                            <option value="Thành phố">Thành phố</option>
                        </select>
                        <span asp-validation-for="LoaiTinh" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="TrangThai" class="form-label fw-bold"> Trạng Thái</label>
                        <select asp-for="TrangThai" class="form-select">
                            <option value="Còn Hoạt Động">Còn Hoạt Động</option>
                            <option value="Đã Sáp Nhập">Đã Sáp Nhập</option>
                        </select>
                        <span asp-validation-for="LoaiTinh" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="VungDiaLy" class="form-label fw-bold">Vùng Địa Lý</label>
                        <select asp-for="VungDiaLy" class="form-select">
                            <option value="">-- Chọn vùng địa lý --</option>
                            <option value="Trung du và miền núi Bắc Bộ">Trung du và miền núi Bắc Bộ</option>
                            <option value="Đồng bằng sông Hồng">Đồng bằng sông Hồng</option>
                            <option value="Bắc Trung Bộ">Bắc Trung Bộ</option>
                            <option value="Duyên hải Nam Trung Bộ">Duyên hải Nam Trung Bộ</option>
                            <option value="Tây Nguyên">Tây Nguyên</option>
                            <option value="Đông Nam Bộ">Đông Nam Bộ</option>
                            <option value="Đồng bằng sông Cửu Long">Đồng bằng sông Cửu Long</option>
                        </select>
                        <span asp-validation-for="VungDiaLy" class="text-danger"></span>
                    </div>

                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="DienTich" class="form-label fw-bold">Diện Tích</label>
                        <input asp-for="DienTich" class="form-control" placeholder="Diện tích (km²)" />
                        <span asp-validation-for="DienTich" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DanSo" class="form-label fw-bold">Dân Số</label>
                        <input asp-for="DanSo" class="form-control" placeholder="Dân số" />
                        <span asp-validation-for="DanSo" class="text-danger"></span>
                    </div>
                </div>

                
                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label fw-bold">Ghi Chú</label>
                    <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Ghi chú thêm..."></textarea>
                    <span asp-validation-for="GhiChu" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn btn-success me-2">
                        <i class="bi bi-plus-circle"></i> Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
