@model QLSNT.Models.XaMoi

@{
    ViewData["Title"] = "Thêm Xã mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Thêm Xã mới</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <!-- Ẩn Mã xã vì là Identity -->
            <input type="hidden" asp-for="MaXaMoi" />

            <!-- Ẩn Mã tỉnh nếu gán tự động -->
            <input type="hidden" asp-for="MaTinh" />

            <div class="mb-3">
                <label asp-for="TenXaMoi" class="form-label"></label>
                <input asp-for="TenXaMoi" class="form-control" />
                <span asp-validation-for="TenXaMoi" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LoaiXa" class="form-label"></label>
                <select asp-for="LoaiXa" class="form-select">
                    <option value="">-- Chọn loại xã --</option>
                    <option value="Xã">Xã</option>
                    <option value="Phường">Phường</option>
                    <option value="Thị trấn">Thị trấn</option>
                    <option value="Đặc khu">Đặc khu</option>
                </select>
                <span asp-validation-for="LoaiXa" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="">-- Chọn trạng thái --</option>
                    <option value="Sáp nhập">Sáp nhập</option>
                    <option value="Giữ nguyên">Giữ nguyên</option>
                </select>
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DanSo" class="form-label"></label>
                <input asp-for="DanSo" class="form-control" />
                <span asp-validation-for="DanSo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DienTich" class="form-label"></label>
                <input asp-for="DienTich" class="form-control" />
                <span asp-validation-for="DienTich" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="GhiChu" class="form-label"></label>
                <textarea asp-for="GhiChu" class="form-control" rows="3"></textarea>
                <span asp-validation-for="GhiChu" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Lưu</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
