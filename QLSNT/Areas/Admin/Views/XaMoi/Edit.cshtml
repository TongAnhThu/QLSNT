@model QLSNT.Models.XaMoi

@{
    ViewData["Title"] = "Cập nhật Xã mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-pencil-square"></i> @ViewData["Title"]</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <!-- Ẩn Mã xã vì là Identity -->
                <input type="hidden" asp-for="MaXaMoi" />

                <!-- Tên xã -->
                <div class="mb-3">
                    <label asp-for="TenXaMoi" class="form-label fw-bold">Tên xã</label>
                    <input asp-for="TenXaMoi" class="form-control" placeholder="Nhập tên xã..." />
                    <span asp-validation-for="TenXaMoi" class="text-danger"></span>
                </div>

                <!-- Loại xã -->
                <div class="mb-3">
                    <label asp-for="LoaiXa" class="form-label fw-bold">Loại xã</label>
                    <select asp-for="LoaiXa" class="form-select">
                        <option value="">-- Chọn loại xã --</option>
                        <option value="Xã">Xã</option>
                        <option value="Phường">Phường</option>
                        <option value="Thị trấn">Thị trấn</option>
                        <option value="Đặc khu">Đặc khu</option>
                    </select>
                    <span asp-validation-for="LoaiXa" class="text-danger"></span>
                </div>

                <!-- Trạng thái -->
                <div class="mb-3">
                    <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái</label>
                    <select asp-for="TrangThai" class="form-select">
                        <option value="">-- Chọn trạng thái --</option>
                        <option value="Giữ nguyên">Giữ nguyên</option>
                        <option value="Sáp nhập">Sáp nhập</option>
                    </select>
                    <span asp-validation-for="TrangThai" class="text-danger"></span>
                </div>

                <!-- Tỉnh mới (FK) -->
                <div class="mb-3">
                    <label asp-for="MaTinh" class="form-label fw-bold">Thuộc tỉnh</label>
                    <select asp-for="MaTinh" class="form-select"
                            asp-items="@(ViewBag.TinhList as IEnumerable<SelectListItem>)">
                        <option value="">-- Chọn tỉnh --</option>
                    </select>
                    <span asp-validation-for="MaTinh" class="text-danger"></span>
                </div>

                <!-- Dân số -->
                <div class="mb-3">
                    <label asp-for="DanSo" class="form-label fw-bold">Dân số</label>
                    <input asp-for="DanSo" class="form-control" placeholder="Nhập dân số..." />
                    <span asp-validation-for="DanSo" class="text-danger"></span>
                </div>

                <!-- Diện tích -->
                <div class="mb-3">
                    <label asp-for="DienTich" class="form-label fw-bold">Diện tích (km²)</label>
                    <input asp-for="DienTich" class="form-control" placeholder="Nhập diện tích..." />
                    <span asp-validation-for="DienTich" class="text-danger"></span>
                </div>

                <!-- Ghi chú -->
                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label fw-bold">Ghi chú</label>
                    <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Thêm ghi chú nếu có..."></textarea>
                    <span asp-validation-for="GhiChu" class="text-danger"></span>
                </div>

                <!-- Nút thao tác -->
                <div class="d-flex justify-content-end mt-3">
                    <button type="submit" class="btn btn-success me-2">
                        <i class="bi bi-save"></i> Lưu thay đổi
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
