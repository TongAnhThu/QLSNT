@model QLSNT.Models.NguoiDan

@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<h2 class="text-primary mb-3">@ViewData["Title"]</h2>

<div class="card mb-3">
    <div class="card-header fw-bold">Thông tin cơ bản</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Số CCCD</dt>
            <dd class="col-sm-9">@Model.MaCCCD</dd>

            <dt class="col-sm-3">Họ tên</dt>
            <dd class="col-sm-9">@Model.HoTen</dd>

            <dt class="col-sm-3">Giới tính</dt>
            <dd class="col-sm-9">@Model.GioiTinh</dd>

            <dt class="col-sm-3">Ngày sinh</dt>
            <dd class="col-sm-9">@Model.NgaySinh?.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Nơi sinh</dt>
            <dd class="col-sm-9">@Model.NoiSinh</dd>

            <dt class="col-sm-3">Nghề nghiệp</dt>
            <dd class="col-sm-9">@Model.NgheNghiep</dd>

            <dt class="col-sm-3">Nơi làm việc</dt>
            <dd class="col-sm-9">@Model.NoiLamViec</dd>

            <dt class="col-sm-3">Tình trạng hôn nhân</dt>
            <dd class="col-sm-9">@Model.TinhTrangHonNhan</dd>

            <dt class="col-sm-3">Trạng thái công dân</dt>
            <dd class="col-sm-9">@Model.TrangThaiCongDan</dd>
        </dl>
    </div>
</div>

<div class="card">
    <div class="card-header fw-bold">Thông tin bổ sung</div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Quan hệ chủ hộ</dt>
            <dd class="col-sm-9">@Model.QuanHeChuHo?.TenQHCH</dd>

            <dt class="col-sm-3">Tôn giáo</dt>
            <dd class="col-sm-9">@Model.TonGiao?.TenTonGiao</dd>

            <dt class="col-sm-3">Dân tộc</dt>
            <dd class="col-sm-9">@Model.DanToc?.TenDanToc</dd>

            <dt class="col-sm-3">Trình độ văn hóa</dt>
            <dd class="col-sm-9">@Model.TrinhDoVanHoa?.TenTDVH</dd>
        </dl>
    </div>
</div>
