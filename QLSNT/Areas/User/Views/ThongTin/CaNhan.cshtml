@model QLSNT.Models.NguoiDan

@{
    ViewData["Title"] = "Thông tin của tôi";
}

<h2 class="text-primary">@ViewData["Title"]</h2>

<div class="card">
    <div class="card-header fw-bold">Thông tin cơ bản</div>
    <div class="card-body">
        <p><strong>CCCD:</strong> @Model.MaCCCD</p>
        <p><strong>Họ tên:</strong> @Model.HoTen</p>
        <p><strong>Ngày sinh:</strong> @Model.NgaySinh?.ToString("dd/MM/yyyy")</p>
        <p><strong>Giới tính:</strong> @Model.GioiTinh</p>
        <p><strong>Nghề nghiệp:</strong> @Model.NgheNghiep</p>
        <p><strong>Nơi làm việc:</strong> @Model.NoiLamViec</p>
    </div>
</div>

<div class="card mt-3">
    <div class="card-header fw-bold">Thông tin bổ sung</div>
    <div class="card-body">
        <p><strong>Dân tộc:</strong> @Model.DanToc?.TenDanToc</p>
        <p><strong>Tôn giáo:</strong> @Model.TonGiao?.TenTonGiao</p>
        <p><strong>Trình độ văn hóa:</strong> @Model.TrinhDoVanHoa?.TenTDVH</p>
    </div>
</div>
